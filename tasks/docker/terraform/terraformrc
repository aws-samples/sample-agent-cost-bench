# Terraform CLI config used inside the verify image. The AWS / null / random
# providers are installed only from the pre-warmed offline mirror, so
# `terraform init` succeeds with --network=none. Any other provider would fall
# through to "direct" (network) and therefore fail offline — tasks should use
# only these providers.
provider_installation {
  filesystem_mirror {
    path = "/opt/tf-mirror"
    include = [
      "registry.terraform.io/hashicorp/aws",
      "registry.terraform.io/hashicorp/null",
      "registry.terraform.io/hashicorp/random",
    ]
  }
  direct {
    exclude = [
      "registry.terraform.io/hashicorp/aws",
      "registry.terraform.io/hashicorp/null",
      "registry.terraform.io/hashicorp/random",
    ]
  }
}
